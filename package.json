{
  "name": "lunar-date-picker",
  "version": "1.0.0",
  "description": "移动端公历/农历日期选择器，支持 Vue 3 和 React 18",
  "keywords": [
    "date-picker",
    "lunar",
    "calendar",
    "vue",
    "react",
    "mobile",
    "农历"
  ],
  "author": "Gavinoio <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gavinoio/lunar-date-picker.git"
  },
  "bugs": {
    "url": "https://github.com/Gavinoio/lunar-date-picker/issues"
  },
  "homepage": "https://github.com/Gavinoio/lunar-date-picker#readme",
  "main": "./dist/core.js",
  "module": "./dist/core.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core.mjs",
      "require": "./dist/core.js",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js",
      "types": "./dist/vue.d.ts"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css",
    "*.vue"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.2.0",
    "terser": "^5.46.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^4.1.0",
    "vue": "^3.4.0"
  }
}
